# ─── Charming UI Production Config ─────────────────────────
# Copy this to .env.production and fill in your values
# Usage: docker compose --env-file .env.production up -d

# ── API Keys (at least one required) ────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# DeepSeek/OpenAI keys can be set later in the web UI Settings

# ── Domain & Ports ──────────────────────────────────────────
# Public domain (used for CORS and OAuth redirects, if any)
DOMAIN=charming.yourdomain.com
# Frontend port on host
FRONTEND_PORT=80

# ── Data ────────────────────────────────────────────────────
# Host directory for persistent data (sessions, settings, projects)
DATA_DIR=./data

# ── Optional ────────────────────────────────────────────────
# LOG_LEVEL=info
# ANTHROPIC_API_KEY_2=sk-ant-...
# OPENAI_API_KEY=sk-...
